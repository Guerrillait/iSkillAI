rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isVerifiedUser() { return isSignedIn() && request.auth.token.email_verified == true; }

    // --- User Profile Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'dob', 'email', 'phone', 'linkedinUrl', 'githubUrl', 'createdAt', 'updatedAt'])
        && data.firstName is string && data.firstName.size() <= 100
        && data.lastName is string && data.lastName.size() <= 100
        && data.dob is string && data.dob.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && data.email is string && data.email == request.auth.token.email
        && data.phone is string && data.phone.size() <= 20
        && data.linkedinUrl is string && data.linkedinUrl.size() <= 500
        && data.githubUrl is string && data.githubUrl.size() <= 500
        && (data.extraLink == null || (data.extraLink is string && data.extraLink.size() <= 500))
        && (data.extraLinkType == null || (data.extraLinkType is string && data.extraLinkType.size() <= 50))
        && (data.primarySector == null || (data.primarySector is string && data.primarySector.size() <= 100))
        && (data.skillScore == null || (data.skillScore is number && data.skillScore >= 0 && data.skillScore <= 100))
        && (data.isAnalyzed == null || data.isAnalyzed is bool);
    }

    match /users/{userId} {
      allow get: if isSignedIn(); // Searchable by anyone signed in IF they know the path (uid)
      
      // List (Search) logic: 
      // Rule enforces that any query MUST filter by at least some fields to prevent full listing
      // However, we MUST evaluating resource.data
      allow list: if isSignedIn() 
                  && resource.data.firstName != null 
                  && resource.data.dob != null; 

      allow create: if isOwner(userId) 
                    && isVerifiedUser()
                    && isValidUser(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time
                    && incoming().isAnalyzed == false; // Initial status

      allow update: if isOwner(userId)
                    && isVerifiedUser()
                    && isValidUser(incoming())
                    && incoming().updatedAt == request.time
                    && incoming().createdAt == existing().createdAt
                    && (
                      // Only allow AI fields update if certain conditions? 
                      // For now, owner can update links, but AI score is preserved or managed
                      incoming().diff(existing()).affectedKeys().hasOnly(['firstName', 'lastName', 'phone', 'linkedinUrl', 'githubUrl', 'extraLink', 'extraLinkType', 'updatedAt'])
                      || (incoming().isAnalyzed == true && incoming().diff(existing()).affectedKeys().hasOnly(['isAnalyzed', 'primarySector', 'skillScore', 'updatedAt']))
                    );
    }
  }
}
